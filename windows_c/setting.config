# Cloudflare IP 优选工具配置  (v1.1.0)
# 重新配置请运行：cf_updater.exe --setup

# ── 输入源 ──
input_file=ips.txt
input_url=https://zip.cm.edu.kg/all.txt
download_input=true
download_timeout=30

# ── 输出文件 ──
full_output_file=full_ips.txt
best_output_file=best_ips.txt

# ── README 生成 ──
update_readme=true
readme_file=README.MD
raw_base_url=https://raw.githubusercontent.com/HandsomeMJZ/cfip/refs/heads/main
test_location=中国四川联通
update_frequency=每半小时自动更新

# ── TCP 与下载测速 ──
tcp_timeout_ms=1500
tcp_workers=500
speed_timeout_sec=3
speed_process_buffer_sec=5
speed_workers=32
min_speed_mbps=12.00
top_per_region=8
max_nodes=0
verbose=false
fast_label=优选高速

# ── GitHub 推送（github_token 可留空，程序会读取环境变量）──
github_upload_enabled=false
github_repo=https://github.com/HandsomeMJZ/cfip.git
github_branch=main
github_workdir=.github-sync
github_message=更新 IP 结果和 README
github_token=
github_token_env=GITHUB_TOKEN
github_full_path=full_ips.txt
github_best_path=best_ips.txt
github_include_readme=true
github_readme_path=README.MD
github_push_retries=3
github_retry_delay_sec=10
git_timeout_sec=180

# ── Git 代理（示例：http://127.0.0.1:7890）──
git_http_proxy=
git_https_proxy=
